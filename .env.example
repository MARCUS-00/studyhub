# ─── Database (Supabase PostgreSQL) ───────────────────────────────────────────
# Rotate the password in the Supabase dashboard under Settings → Database → Reset password.
# Use the pooler URL (port 6543) for DATABASE_URL and the direct URL (port 5432) for DIRECT_URL.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# ─── NextAuth ─────────────────────────────────────────────────────────────────
# Generate a strong secret: openssl rand -base64 32
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# ─── Supabase (public keys — safe to expose in browser) ───────────────────────
# Used for: Storage uploads (notes PDFs, avatars), public content reads.
# All DB writes now go through server-side Prisma routes; these keys are read-only in practice.
NEXT_PUBLIC_SUPABASE_URL="https://<project>.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="<anon-key>"

# ─── SMTP (required for OTP emails) ───────────────────────────────────────────
# Used for: signup email verification OTP and forgot-password OTP.
# Without these, OTPs are printed to the server console (dev-only fallback).
# Tested providers: SendGrid, Resend, Mailtrap, Gmail SMTP.
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER="noreply@example.com"
SMTP_PASS="your-smtp-password"
SMTP_FROM="StudyHub <noreply@example.com>"
